# === Required ===
GITHUB_TOKEN=ghp_...                  # Agent GitHub operations

# === COO LLM Provider (pick ONE) ===
# OpenRouter (recommended — 200+ models, free tiers available)
OPENROUTER_API_KEY=sk-or-...
# Anthropic (direct)
# ANTHROPIC_API_KEY=sk-ant-...
# OpenAI
# OPENAI_API_KEY=sk-...
# Google Gemini
# GOOGLE_API_KEY=...
# Local LLM (Ollama — no key needed, just set the base URL)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# === Optional (recommended) ===
TELEGRAM_BOT_TOKEN=123456:ABC...      # COO → CEO alerts
TELEGRAM_ALLOWED_USERS=your_user_id   # Your Telegram numeric ID

# === Paperclip ===
PAPERCLIP_URL=http://localhost:3100   # Paperclip server URL
# DATABASE_URL=                       # Leave blank for embedded PGlite

# === Claude Code (for claude_local agents) ===
# No API key needed for personal use — agents use `claude -p` with your Max subscription
# For production/API mode, uncomment:
# ANTHROPIC_API_KEY=sk-ant-...
